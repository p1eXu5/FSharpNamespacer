  <Target Name="IncrementBuildVersion" BeforeTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <VsixManifestPath>$(ProjectDir)source.extension.vsixmanifest</VsixManifestPath>
    </PropertyGroup>
    <!-- Read the manifest file -->
    <XmlPeek XmlInputPath="$(VsixManifestPath)" Query="/ns:PackageManifest/ns:Metadata/ns:Identity/@Version" Namespaces="&lt;Namespace Prefix='ns' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;">
      <Output TaskParameter="Result" ItemName="CurrentVersion" />
    </XmlPeek>
    <PropertyGroup>
      <FullVersion>@(CurrentVersion)</FullVersion>
      <!-- Check if +build. segment exists -->
      <HasBuildMeta Condition="$(FullVersion.Contains('+build.'))">true</HasBuildMeta>
      <HasBuildMeta Condition="!$(FullVersion.Contains('+build.'))">false</HasBuildMeta>
      <!-- Extract base version (before +build.) -->
      <BaseVersion Condition="'$(HasBuildMeta)' == 'true'">$(FullVersion.Substring(0, $(FullVersion.IndexOf('+build.'))))</BaseVersion>
      <BaseVersion Condition="'$(HasBuildMeta)' == 'false'">$(FullVersion)</BaseVersion>
      <!-- Extract current build number or default to 0 -->
      <BuildMetaPrefix>+build.</BuildMetaPrefix>
      <CurrentBuildNumber Condition="'$(HasBuildMeta)' == 'true'">$(FullVersion.Substring($([MSBuild]::Add($(FullVersion.IndexOf('+build.')), 7))))</CurrentBuildNumber>
      <CurrentBuildNumber Condition="'$(HasBuildMeta)' == 'false'">0</CurrentBuildNumber>
      <!-- Increment -->
      <NewBuildNumber>$([MSBuild]::Add($(CurrentBuildNumber), 1))</NewBuildNumber>
      <!-- Compose new version -->
      <NewVersion>$(BaseVersion)+build.$(NewBuildNumber)</NewVersion>
    </PropertyGroup>
    <Message Importance="high" Text="VSIX Version: $(FullVersion) -&gt; $(NewVersion)" />
    <!-- Write back to manifest -->
    <XmlPoke XmlInputPath="$(VsixManifestPath)" Query="/ns:PackageManifest/ns:Metadata/ns:Identity/@Version" Value="$(NewVersion)" Namespaces="&lt;Namespace Prefix='ns' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;" />
  </Target>
